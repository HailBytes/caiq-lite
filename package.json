{
  "name": "@hailbytes/caiq-lite",
  "version": "0.0.1",
  "description": "Programmatic schema and validator for the CSA CAIQ-Lite vendor security questionnaire. Author, validate, and diff CAIQ responses as code.",
  "type": "module",
  "license": "MIT",
  "author": "HailBytes, LLC",
  "keywords": [
    "caiq",
    "csa",
    "vendor-security",
    "questionnaire",
    "compliance",
    "soc2",
    "iso27001",
    "trust-center",
    "security-questionnaire",
    "hailbytes"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HailBytes/caiq-lite.git"
  },
  "bugs": {
    "url": "https://github.com/HailBytes/caiq-lite/issues"
  },
  "homepage": "https://hailbytes.com",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "js-yaml": "^4.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
